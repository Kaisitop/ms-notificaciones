NATS_SERVICE=nats://localhost:4222

FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DASHBOARD_URL=http://localhost:3001

# --- Envío de correos (obligatorio) ---
#
# Opción A — Gmail / Google Workspace (recomendado si ya tienes cuenta institucional)
#   1. Activa verificación en 2 pasos: https://myaccount.google.com/security
#   2. Crea App Password: Seguridad → Contraseñas de aplicaciones → "Correo"
#   3. Usa la contraseña de 16 caracteres (sin espacios) en SMTP_PASS
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=tu_cuenta@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx
#   MAIL_FROM=Centinela <tu_cuenta@gmail.com>
#
# Opción B — Mailtrap Sandbox (solo pruebas, correos no llegan a bandejas reales)
#   SMTP_HOST=sandbox.smtp.mailtrap.io
#   SMTP_PORT=2525
#
# Opción C — Mailtrap Sending (producción, requiere DNS verificado en unemi.edu.ec)
#   SMTP_HOST=live.smtp.mailtrap.io
#   SMTP_PORT=587
#   SMTP_USER=api
#   SMTP_PASS=<api_token>
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Centinela <tu_cuenta@gmail.com>
PUBLIC_WEB_URL=http://localhost:3001
APP_RESET_URL=centinela://reset-password